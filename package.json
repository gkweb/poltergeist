{
  "name": "poltergeist-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm --filter @poltergeist-ai/cli run build",
    "typecheck": "pnpm --filter @poltergeist-ai/cli run typecheck",
    "dev": "pnpm --filter @poltergeist-ai/cli run dev",
    "test": "pnpm --filter @poltergeist-ai/cli run test",
    "docs:dev": "pnpm --filter @poltergeist-ai/docs run dev",
    "docs:build": "pnpm --filter @poltergeist-ai/docs run build",
    "docs:preview": "pnpm --filter @poltergeist-ai/docs run preview",
    "release": "pnpm --filter @poltergeist-ai/cli exec npm version patch && pnpm --filter @poltergeist-ai/cli publish --access public"
  }
}
